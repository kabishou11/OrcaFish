# OrcaFish — Unified Intelligence System

# App
APP_HOST=0.0.0.0
APP_PORT=8080
DEBUG=true

# ============================================================
# LLM Providers (默认全部使用 ModelScope Qwen3.5-35B-A3B)
# ============================================================
# ModelScope Token: https://modelscope.cn
MODELSCOPE_API_KEY=your-modelscope-api-key

# Query Agent (舆情搜索)
QUERY_LLM_PROVIDER=modelscope
QUERY_LLM_API_KEY=your-query-llm-api-key
QUERY_LLM_BASE_URL=https://api-inference.modelscope.cn/v1
QUERY_LLM_MODEL=Qwen/Qwen3.5-35B-A3B
QUERY_LLM_TIMEOUT=300
QUERY_LLM_REASONING_SPLIT=false

# Media Agent (多模态搜索)
MEDIA_LLM_PROVIDER=modelscope
MEDIA_LLM_API_KEY=your-media-llm-api-key
MEDIA_LLM_BASE_URL=https://api-inference.modelscope.cn/v1
MEDIA_LLM_MODEL=Qwen/Qwen3.5-35B-A3B
MEDIA_LLM_TIMEOUT=300
MEDIA_LLM_REASONING_SPLIT=false

# Insight Agent (社交媒体)
INSIGHT_LLM_PROVIDER=modelscope
INSIGHT_LLM_API_KEY=your-insight-llm-api-key
INSIGHT_LLM_BASE_URL=https://api-inference.modelscope.cn/v1
INSIGHT_LLM_MODEL=Qwen/Qwen3.5-35B-A3B
INSIGHT_LLM_TIMEOUT=300
INSIGHT_LLM_REASONING_SPLIT=false

# Report Agent (HTML报告生成)
REPORT_LLM_PROVIDER=modelscope
REPORT_LLM_API_KEY=your-report-llm-api-key
REPORT_LLM_BASE_URL=https://api-inference.modelscope.cn/v1
REPORT_LLM_MODEL=Qwen/Qwen3.5-35B-A3B
REPORT_LLM_TIMEOUT=300
REPORT_LLM_REASONING_SPLIT=false

# ============================================================
# MiniMax（可选 OpenAI 兼容配置）
# 官方 OpenAI 兼容地址: https://api.minimaxi.com/v1
# 推荐模型: MiniMax-M2.7
# 若需要 reasoning_details，可将 *_REASONING_SPLIT 设为 true
# ============================================================
MINIMAX_API_KEY=your-minimax-api-key

# ============================================================
# Knowledge Graph (Zep Cloud)
# ============================================================
ZEP_API_KEY=

# ============================================================
# Intelligence Data Sources
# ============================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
ACLED_ACCESS_TOKEN=
UCDP_ACCESS_TOKEN=
TAVILY_API_KEY=

# ============================================================
# BettaFish Social Media DB (optional)
# ============================================================
DATABASE_URL=

# ============================================================
# Trigger Thresholds
# ============================================================
CII_THRESHOLD=65.0
CONVERGENCE_MIN_SIGNALS=3
COOLDOWN_SECONDS=3600
WORLDMONITOR_POLL_INTERVAL=300
MILITARY_ZSCORE_THRESHOLD=2.0

# ============================================================
# Simulation
# ============================================================
SIMULATION_ROUNDS=40
SIMULATION_TIMEOUT=3600
